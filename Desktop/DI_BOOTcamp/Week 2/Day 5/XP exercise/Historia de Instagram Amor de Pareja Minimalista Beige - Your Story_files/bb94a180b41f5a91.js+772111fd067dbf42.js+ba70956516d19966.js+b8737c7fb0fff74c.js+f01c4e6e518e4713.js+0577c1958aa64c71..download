(function() {
 const messages = JSON.parse("{\"o5MrXg\":\"“Good design is good business.” <strong>— Thomas Watson Jr</strong>\",\"vqrTKA\":\"“Creativity is intelligence having fun.” <strong>— Albert Einstein</strong>\",\"PNdOmA\":\"“An essential aspect of creativity is not being afraid to fail.” <strong>— Dr. Edwin Land</strong>\",\"fLi3qg\":\"“The people who are crazy enough to think they can change the world are the ones who do.” <strong>— Steve Jobs et al.</strong>\",\"PIOarg\":\"“Creativity is inventing, experimenting, growing, taking risks, breaking rules, making mistakes and having fun.” <strong>— Mary Lou Cook</strong>\",\"XjD+cQ\":\"“Great design is eliminating all unnecessary details.” <strong>— Minh D. Tran</strong>\",\"kHgvew\":\"“There are three responses to a piece of design — yes, no, and WOW! Wow is the one to aim for.” <strong>— Milton Glaser</strong>\",\"WseK1g\":\"“It always seems impossible until it’s done.” <strong>— Nelson Mandela</strong>\",\"KKkgTA\":\"“Do one thing every day that scares you.” <strong>— Eleanor Roosevelt</strong>\",\"jOGwEg\":\"”Creativity takes courage.” <strong>— Henri Matisse</strong>\",\"7JDYTg\":\"“Creativity is a combination of discipline and a childlike spirit.” <strong>— Robert Greene</strong>\",\"uzsGNQ\":\"“Good design encourages a viewer to want to learn more.” <strong>— Alexander Isley</strong>\",\"Pj9wzw\":\"“You are ready. Start making stuff.” <strong>— Austin Kleon</strong>\",\"+BsX1A\":\"“The best way to predict your future is to create it.” <strong>— Abraham Lincoln</strong>\",\"NW8utQ\":\"“Design is the silent ambassador of your brand.” <strong>— Paul Rand</strong>\",\"6YwKnA\":\"“Everything has its beauty, but not everyone sees it.” <strong>— Confucius</strong>\",\"4va6eg\":\"“Perfection is achieved, not when there is nothing more to add, but when there is nothing left to take away.” <strong>— Antoine de Saint-Exupéry</strong>\",\"pdz/fw\":\"“The aim of art is to represent not the outward appearance of things, but their inward significance.” <strong>— Aristotle</strong>\",\"22B/gw\":\"“Success is liking yourself, liking what you do, and liking how you do it.” <strong>— Maya Angelou</strong>\",\"aiAH5A\":\"“Be not afraid of going slowly, be afraid of standing still.” <strong>— Chinese Proverb</strong>\",\"nIguog\":\"“Design has allowed us to stand out; to look different and show that difference boldly.” <strong>— Joe Mansueto</strong>\",\"o5QTWg\":\"“Good friends, good books and a sleepy conscience: this is the ideal life.” <strong>— Mark Twain</strong>\",\"f1pl+Q\":\"“Design is a plan for arranging elements in a way that best accomplishes a particular purpose.” <strong>— Charles Eames</strong>\"}");
